<Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Windows Configuration &amp; Optimization Framework" 
    Height="650" Width="900" 
    Background="#121212" 
    WindowStartupLocation="CenterScreen" 
    FontFamily="Segoe UI" 
    ResizeMode="CanMinimize">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Custom ScrollBar Styling (Ultra Minimal) -->
        <Style x:Key="ScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#333333" CornerRadius="3" Margin="4,0,0,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00adb5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Content="{TemplateBinding ScrollViewer.Content}" />
                            <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2a2a"/>
                    <Setter Property="BorderBrush" Value="#00adb5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00adb5" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#00adb5"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary Accent Button -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#00adb5"/>
            <Setter Property="Foreground" Value="#121212"/>
            <Setter Property="BorderBrush" Value="#00adb5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00adb5" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00cfd9"/>
                    <Setter Property="BorderBrush" Value="#00cfd9"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#00cfd9" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#008a90"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#ff5722"/>
            <Setter Property="BorderBrush" Value="#ff5722"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ff5722"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Padding="20,10" BorderThickness="0,0,0,2" BorderBrush="Transparent" Background="Transparent" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00adb5" />
                                <Setter Property="Foreground" Value="#00adb5" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#888888" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#ffffff" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" IsItemsHost="True" Orientation="Horizontal" Background="#121212" Margin="0,0,0,10"/>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBlocks -->
        <Style x:Key="Header1" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00adb5"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="Header2" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>

        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#a0a0a0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Cards -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#00adb5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00adb5" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20,30,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Add a custom drag area since we're using WindowChrome -->
        <Border Grid.RowSpan="3" VerticalAlignment="Top" Height="30" Margin="-20,-30,-20,0" Background="Transparent" WindowChrome.IsHitTestVisibleInChrome="True"/>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource Header1}" Text="Optimization Framework"/>
        </StackPanel>

        <!-- Main Content (Tabs) -->
        <TabControl Grid.Row="1">
            <!-- TABS: Profiles -->
            <TabItem Header="PROFILES">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel Margin="0,10,0,10">
                        <TextBlock Style="{StaticResource BodyText}" Text="Select an orchestrator profile below. Applying a profile automatically captures a state snapshot for secure rollback." Margin="0,0,0,20"/>
                        
                        <!-- Profile Card 1 -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE945;" FontSize="20" Foreground="#00adb5" Margin="0,15,10,10" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource Header2}" Text="Max Performance Profile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource BodyText}" Text="Target: Esports Gamers, Audio Producers, Latency Obsessives. Strips telemetry, disables mouse acceleration, enforces WASAPI exclusive mode."/>
                                </StackPanel>
                                <Button Name="BtnApplyMaxPerf" Grid.Column="1" Style="{StaticResource AccentButton}" Width="140" Height="40">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE768;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Apply Profile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Profile Card 2 -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8F1;" FontSize="20" Foreground="#00adb5" Margin="0,15,10,10" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource Header2}" Text="Balanced Creator Profile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource BodyText}" Text="Target: Developers, Video Editors, Power Users. Optimizes Explorer and removes UI bloat while retaining Windows Update and standard drivers."/>
                                </StackPanel>
                                <Button Name="BtnApplyBalanced" Grid.Column="1" Style="{StaticResource AccentButton}" Width="140" Height="40">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE768;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Apply Profile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Profile Card 3 -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE773;" FontSize="20" Foreground="#00adb5" Margin="0,15,10,10" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource Header2}" Text="Enterprise Compliance Profile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource BodyText}" Text="Target: SysAdmins, Corporate Devices. Enforces HVCI/Memory Integrity, strict firewall rules, telemetry isolation, blocks consumer bloatware."/>
                                </StackPanel>
                                <Button Name="BtnApplyEnterprise" Grid.Column="1" Style="{StaticResource AccentButton}" Width="140" Height="40">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE768;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Apply Profile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TABS: Observability -->
            <TabItem Header="OBSERVABILITY">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel Margin="0,10,0,10">
                        <TextBlock Style="{StaticResource BodyText}" Text="Real-time native telemetry polling via WMI and Performance Counters. Monitoring system bottlenecks and scheduling behavior." Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Left Column -->
                            <StackPanel Grid.Column="0">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE909;" FontSize="20" Foreground="#00adb5" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Style="{StaticResource Header2}" Text="System Interrupts (DPC/sec)" Margin="0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Name="TxtDpcLatency" Foreground="#ffffff" FontSize="36" FontWeight="Light" Text="--"/>
                                        <TextBlock Style="{StaticResource BodyText}" Text="Hardware interrupt latency. Lower is better." Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="20" Foreground="#00adb5" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Style="{StaticResource Header2}" Text="Available Memory (MB)" Margin="0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Name="TxtMemAvailable" Foreground="#ffffff" FontSize="36" FontWeight="Light" Text="--"/>
                                        <TextBlock Style="{StaticResource BodyText}" Text="Unused physical memory." Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Right Column -->
                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE783;" FontSize="20" Foreground="#00adb5" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Style="{StaticResource Header2}" Text="System Uptime" Margin="0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Name="TxtUptime" Foreground="#ffffff" FontSize="36" FontWeight="Light" Text="--"/>
                                        <TextBlock Style="{StaticResource BodyText}" Text="Time since last cold boot." Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8D8;" FontSize="20" Foreground="#00adb5" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Style="{StaticResource Header2}" Text="Process Count" Margin="0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Name="TxtProcessCount" Foreground="#ffffff" FontSize="36" FontWeight="Light" Text="--"/>
                                        <TextBlock Style="{StaticResource BodyText}" Text="Active background processes &amp; services." Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Header2}" Text="Observability Actions" Margin="0,0,0,10"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Name="BtnAnalyzeFrameTiming" Grid.Column="0" Content="Analyze Frame Timing &amp; Queues" Height="40"/>
                                    <Button Name="BtnMeasureBootTime" Grid.Column="2" Content="Measure Boot Time" Height="40"/>
                                </Grid>
                                
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Name="BtnGenerateReport" Grid.Column="0" Style="{StaticResource AccentButton}" Content="Generate Performance HTML Report" Height="40"/>
                                    <Button Name="BtnDetectThirdParty" Grid.Column="2" Content="Detect Third-Party Benchmarks" Height="40"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TABS: Rollback Engine -->
            <TabItem Header="ROLLBACK ENGINE">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel Margin="0,10,0,10">
                        <TextBlock Style="{StaticResource BodyText}" Text="View captured snapshots and safely rollback configuration states." Margin="0,0,0,20"/>
                        
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Style="{StaticResource Header2}" Text="Transaction Manifests" Margin="0,0,0,10"/>
                                    <ListView Name="ListTransactions" Background="#121212" Foreground="#ffffff" BorderBrush="#333333" Height="250">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding TransactionID}" Width="150"/>
                                                <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="150"/>
                                                <GridViewColumn Header="Profile" DisplayMemberBinding="{Binding Profile}" Width="120"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Button Name="BtnRefreshTransactions" Content="Refresh List" Margin="0,10,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Header2}" Text="Transaction Details" Margin="0,0,0,10"/>
                                    <Border Background="#121212" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="15" Height="250">
                                        <ScrollViewer>
                                            <TextBlock Name="TxtTransactionDetails" Style="{StaticResource BodyText}" Text="Select a transaction to preview changes..."/>
                                        </ScrollViewer>
                                    </Border>
                                    <Button Name="BtnRollbackSelected" Style="{StaticResource DangerButton}" Content="Rollback Selected Transaction" Margin="0,10,0,0" Height="40" IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Style="{StaticResource BodyText}" Text="v5.0 Enterprise Edition" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock Name="TxtStatus" Style="{StaticResource BodyText}" Text="Status: Ready" Foreground="#00adb5" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>
